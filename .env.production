# Meharstare Production Environment Variables
# REPLACE THESE PLACEHOLDERS WITH ACTUAL PRODUCTION VALUES

# Database
# Example: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://<PROD_DB_USER>:<PROD_DB_PASSWORD>@<PROD_DB_HOST>:<PROD_DB_PORT>/<PROD_DB_NAME>"

# NextAuth Configuration
# Run `openssl rand -base64 32` to generate a new secret for production
NEXTAUTH_SECRET="<YOUR_PRODUCTION_NEXTAUTH_SECRET>"
NEXTAUTH_URL="https://www.meharstare.com"

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME="<PROD_CLOUDINARY_CLOUD_NAME>"
CLOUDINARY_API_KEY="<PROD_CLOUDINARY_API_KEY>"
CLOUDINARY_API_SECRET="<PROD_CLOUDINARY_API_SECRET>"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="<PROD_CLOUDINARY_UPLOAD_PRESET>"

# SMTP/Email Configuration (for password resets, order confirmations, etc.)
SMTP_HOST="<PROD_SMTP_HOST>" # e.g., smtp.gmail.com
SMTP_PORT="587"
SMTP_USER="<PROD_SMTP_USER_EMAIL>"
SMTP_PASS="<PROD_SMTP_APP_PASSWORD>"

# WhatsApp Configuration (for customer support)
# Format: Country code + number without plus or spaces
NEXT_PUBLIC_WHATSAPP_NUMBER="<PROD_WHATSAPP_NUMBER>"
